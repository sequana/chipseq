    container:
        config['apptainers']['sequana_tools']
    shell:
        """
        plotFingerprint --bamfiles {input} --plotFile {output.pdf} --labels {params.labels} --outRawCounts {output.raw} --outQualityMetrics {output.metrics} --skipZeros --numberOfProcessors {threads} --numberOfSamples {params.bins} >{log} 2>&1
        """

if config['fingerprints']['do']:
    expected_output += [
            "fingerprints/plotFingerprint.raw.txt",
            "fingerprints/plotFingerprint.qcmetrics.txt",
            "fingerprints/plotFingerprint.pdf"]


# ===================================================== bam to bed
# TODO: scale is hard-coded to 1 but should be derived from the data itself
#shell("samtools flagstat {input[0]} > {input[0]}.flagstats")
#SCALE=`grep 'mapped (' {input[0].flagstats} | awk '{print 1000000/$1}'`
#
rule bam_to_bed:
    input:
        get_final_bam_location("{sample}")
    output:
        bedgraph=temp("{sample}/bigwig/{sample}.bedGraph"),
    log:
        "{sample}/bigwig/{sample}.bam_to_bed.log"
    params:
        paired = " -pc " if manager.paired else " "
    container:
        config['apptainers']['sequana_tools']
    shell:
        """
        genomeCoverageBed -ibam {input[0]} -bg -scale 1  {params.paired} | sort -T '.' -k1,1 -k2,2n >  {output.bedgraph} 2>{log}
        """


# ===================================================== bed to bigwig
rule bed_to_bigwig:
    input:
        bedgraph="{sample}/bigwig/{sample}.bedGraph",
        chrom_sizes="chrom.sizes"
    output:
        bigwig="{sample}/bigwig/{sample}.bigwig"
    log:
        "{sample}/bigwig/{sample}.bed_to_bigwig.log"
    container:
        config['apptainers']['ucsc']
    shell:
        """
        bedGraphToBigWig {input.bedgraph} {input.chrom_sizes} {output.bigwig} >{log} 2>&1
        """


# ===================================================== macs3
rule macs3:
    input:
        inputs = get_IP_macs3,
        controls = get_control_macs3
    output:
        "macs3/{broad_narrow}/{comp}_peaks.{broad_narrow}Peak"
    params:
        bandwidth       = config['macs3']['bandwidth'],
        genome_size     = config['macs3']['genome_size'],
        options         = config['macs3']['options'],
        broad_cutoff    = config['macs3']['broad_cutoff'],
        paired          = manager.paired,
        prefix          = "{comp}",
        qvalue          = config['macs3']['qvalue'],
        mode            = "{broad_narrow}",
        outdir          = "macs3/{broad_narrow}"
    log:
        "macs3/{broad_narrow}/{comp}_out.log"
    container:
        config['apptainers']['macs3']
    shell:
        """
        format_opt="-f BAM"
        if [ "{params.paired}" = "True" ]; then format_opt="-f BAMPE"; fi
        broad_opt=""
        if [ "{params.mode}" = "broad" ]; then
            broad_opt="--broad --broad-cutoff {params.broad_cutoff}"
        fi
        macs3 callpeak -B --SPMR \
            -t {input.inputs} \
            -c {input.controls} \
            -g {params.genome_size} \
            -n {params.prefix} \
            --bw {params.bandwidth} \
            {params.options} \
            -q {params.qvalue} \
            $format_opt \
            $broad_opt \
            --outdir {params.outdir} > {log} 2>&1
        """


# ===================================================== naive consensus summary
if config["idr"]["do"]:
    rule naive_consensus:
        input:
            get_idr_NT_input
        output:
            "macs3/{broad_narrow}/{condition}_venn.png",
        run:
            from sequana.macs3 import PeakConsensus
            from pylab import savefig, title

            pc = PeakConsensus(input[0], input[1])
            if len(pc.df1) and len(pc.df2):
                pc.plot_venn()
                title(f"{wildcards.broad_narrow}/{wildcards.condition}")
                savefig(output[0], dpi=200)

                df_merged = pc.merge()
            else:
                copy_no_data_image(output[0])

    expected_output += expand("macs3/{mode}/{comp}_venn.png", mode=['broad','narrow'], comp=cc.conditions)


# ===================================================== FRiP
rule FRiP:
    input:
        bamfiles=expand("{sample}/{aligner}/{sample}.sorted.bam", sample=manager.samples, aligner=aligner),
        peaks ="macs3/{broad_narrow}/{comparison}_peaks.{broad_narrow}Peak",
    output: "macs3/{broad_narrow}/{comparison}_FRiP.txt"
    threads: 1
    run:

        # intersect takes only one input BAM. It can take several peak inputs
        # though. Here, we use one bam input and one peak input
        import subprocess
        results = {}
        for bamfile in sorted(input.bamfiles):
            cmd = "intersectBed  -a " + bamfile +" -b "+ input.peaks +"  -bed -c -f 0.2|  awk -F '\t' '{sum += $NF; total+=1} END {print sum,total}' "
            res = subprocess.run(cmd, shell=True, stdout=subprocess.PIPE)
            in_peaks, count = (res.stdout.strip().decode()).split()
            count = int(count)
            FRiP = float(in_peaks) / count
            results[bamfile] = {'count': count, 'FRiP': FRiP, 'in_peaks': in_peaks}

        with open(output[0], "w") as fout:
            fout.write("bamfile,count,in_peaks,FRiP,comparison\n")
            for k, v in results.items():
                frip = v['FRiP']
                count = v['count']
                in_peaks = v['in_peaks']
                comparison = wildcards.comparison
                fout.write(f"{k},{count},{in_peaks},{frip},{comparison}\n")


# ===================================================== plot FRiP
rule plot_FRiP:
    input: "macs3/{broad_narrow}/{comparison}_FRiP.txt"
    output: "FRiP/{broad_narrow}/{comparison}_FRiP.png"
    run:
        from sequana.frip import FRiP
        from pylab import savefig
        c = FRiP(input[0])
        c.plot()
        savefig(output[0])



rule QC_plots:
    input:
        frip=expand("FRiP/{broad_narrow}/{comparison}_FRiP.png", comparison=design.keys(), 
                broad_narrow=['broad','narrow']),
        correlation="outputs/correlation.png",
        annotated_peaks=expand("annotate_peaks/{broad_narrow}/{comparison}.png", comparison=design.keys(),
                broad_narrow=['broad','narrow']),
        peak_counts=expand("outputs/peak_{broad_narrow}_counts.png", broad_narrow=['broad','narrow']),
        phantom= expand("{sample}/phantom/phantom.png", sample=manager.samples)
    output:
        "output/qc_plots.done"
    shell:
        """
        touch {output}
        """



# ============================================================== annotation
rule annotate_peaks:
    input:
        macs3="macs3/{broad_narrow}/{comp}_peaks.{broad_narrow}Peak",
        fasta = fasta_file,
        gff   = gff_file
    output:
        annotations = "annotate_peaks/{broad_narrow}/{comp}.txt"
    threads: 1
    log:
        "annotate_peaks/{broad_narrow}/{comp}.log"
    container:
        config['apptainers']['homer']
    shell:
        """
        annotatePeaks.pl {input.macs3} {input.fasta} -gid -gff {input.gff} -cpu {threads} 1>{output.annotations} 2>{log}
        """


# ============================================================== annotation plots
rule plot_annotated_peaks:
    input:
        annotations = "annotate_peaks/{broad_narrow}/{comp}.txt"
    output:
        png = "annotate_peaks/{broad_narrow}/{comp}.png"
    run:
        from sequana.homer import Homer
        from pylab import savefig

        h = Homer(input[0])
        h.pie_annotation()
        savefig(output[0], dpi=200)



########################### IDR ###############################################
if config['idr']['do']:

    # This is the IDR replicate1 versus replicates2
    # Peak consistency between true replicates
    # Nt for Number of True replicates

    # =========================================================================
    # ============================================ true replicates         ====
    # =========================================================================
    rule idr_NT:
        input:
            get_idr_NT_input
        output:
            "IDR/{broad_narrow}/{condition}.csv"
        log:
            out="IDR/{broad_narrow}/{condition}.out",
            err="IDR/{broad_narrow}/{condition}.err"
        params:
            rank=config['idr']['rank'],
            soft_idr_threshold=config['idr']['soft_idr_threshold']
        container:
            config['apptainers']['idr']
        shell:
            """
            idr --samples {input} --input-file-type {wildcards.broad_narrow}Peak --rank {params.rank} \
                --output-file IDR/{wildcards.broad_narrow}/{wildcards.condition} \
                --plot --soft-idr-threshold {params.soft_idr_threshold} \
                1>{log.out} 2>{log.err}
            mv IDR/{wildcards.broad_narrow}/{wildcards.condition} {output}
            """

    rule plot_idr:
        input:
            "IDR/{broad_narrow}/{condition}.csv"
        output:
            image_idr_vs_peaks="IDR/{broad_narrow}/{condition}_idr_vs_peaks.png",
            image_ranks="IDR/{broad_narrow}/{condition}_ranks.png",
            image_scores="IDR/{broad_narrow}/{condition}_scores.png",
            image_rank_idr="IDR/{broad_narrow}/{condition}_rank_idr.png",
            peaks="IDR/{broad_narrow}/{condition}_significative_peaks.{broad_narrow}Peak",
            significative="IDR/{broad_narrow}/{condition}_significative.csv"
        run:
            from sequana.idr import IDR
            idr = IDR(input[0])
            if len(idr.df):
                idr.plot_idr_vs_peaks(output.image_idr_vs_peaks, savefig=True)
                idr.plot_ranks(output.image_ranks, savefig=True)
                idr.plot_scores(output.image_scores, savefig=True)
                idr.plot_rank_vs_idr_score(output.image_rank_idr, savefig=True)


                # save significative peaks with idr format
                tokeep = [x for x in idr.df.columns if x not in ['idr', 'rep2_rank', 'rep1_rank']]
                idr.df.query("idr<0.05")[tokeep].to_csv(output.significative, sep="\t", header=False, index=False)

                # save significative peaks with same format as macs3
                dd = idr.df.query("idr<0.05")[["chrom", "start", "end", "score", "signalValue", "pvalue", "qvalue", "strand"]]
                dd = dd.sort_values("chrom")
                dd['summit'] = 1000 # broad has no summit. narrow may have small value but for this plot, we can assume everything is 1000
                dd['name'] = [f"{wildcards.condition}_{x}" for x in range(1, len(dd)+1)]
                dd = dd[["chrom", "start", "end", "name", "score", "strand", "signalValue", "pvalue", "qvalue", "summit"]]

                dd.to_csv(output.peaks, index=False, sep="\t", header=False)
            else:
                for filename in output:
                    if str(filename).endswith(".csv") or str(filename).endswith("Peak"):
                        open(str(filename), "w").close()  # empty file
                    else:
                        copy_no_data_image(str(filename))


    expected_output += expand("IDR/{broad_narrow}/{condition}_ranks.png",
				broad_narrow=['broad','narrow'],
				condition=cc.conditions)
    expected_output += expand("IDR/{broad_narrow}/{condition}_rank_idr.png",
				broad_narrow=['broad','narrow'],
				condition=cc.conditions)
    expected_output += expand("IDR/{broad_narrow}/{condition}_scores.png",
				broad_narrow=['broad','narrow'],
				condition=cc.get_idr_NT_inputs().keys())
    expected_output += expand("IDR/{broad_narrow}/{condition}_significative_peaks.{broad_narrow}Peak",
				broad_narrow=['broad','narrow'],
				condition=cc.get_idr_NT_inputs().keys())
    expected_output += expand("IDR/{broad_narrow}/{condition}_significative.csv",
				broad_narrow=['broad','narrow'],
				condition=cc.get_idr_NT_inputs().keys())



if config['idr']['do'] and config['idr']['self_pseudo_replicates']:
    # =========================================================================
    # ============================================ self pseudo replicates  ====
    # =========================================================================
    rule self_pseudo_replicates_data:
        input:
            get_final_bam_location("IP_{condition}_rep{rep}")
        output:
            tmp_header=temp("SPR_IDR/{condition}_rep{rep}_SPR{N}_header.txt"),
            tmp_split0=temp("SPR_IDR/{condition}_rep{rep}_SPR{N}00"),
            tmp_split1=temp("SPR_IDR/{condition}_rep{rep}_SPR{N}01"),
            rep1="SPR_IDR/{condition}_rep{rep}_rep1_SPR{N}.bam",
            rep2="SPR_IDR/{condition}_rep{rep}_rep2_SPR{N}.bam"
        log:
            "SPR_IDR/{condition}_rep{rep}_SPR{N}.log"
        container:
            config['apptainers']['sequana_tools']
        shell:
            """
            # how many lines do we have ?
            nlines=$(samtools view {input} | wc -l)
            nlines=$(( (nlines + 1) / 2 ))

            # keep header for later
            samtools view -H {input} 1> {output.tmp_header} 2>> {log}

            # shuffle data and split in 2 files
            samtools view {input} | shuf - | split -d -l ${{nlines}} - SPR_IDR/{wildcards.condition}_rep{wildcards.rep}_SPR{wildcards.N} >> {log}

            cat {output.tmp_header} {output.tmp_split0} | samtools view -bS -> {output.rep1}
            cat {output.tmp_header} {output.tmp_split1} | samtools view -bS -> {output.rep2}
            """

    rule self_pseudo_replicate_peaks:
        input:
            inputs="SPR_IDR/{condition}_rep{rep}_rep{rep2}_SPR{N}.bam",
            controls=get_final_bam_location("Input_{condition}")
        output:
            "SPR_IDR/macs3/{broad_narrow}/{condition}_rep{rep}_rep{rep2}_SPR{N}_peaks.{broad_narrow}Peak"
        params:
            bandwidth       = config['macs3']['bandwidth'],
            genome_size     = config['macs3']['genome_size'],
            options         = config['macs3']['options'],
            broad_cutoff    = config['macs3']['broad_cutoff'],
            paired          = manager.paired,
            prefix          = "{condition}_rep{rep}_rep{rep2}_SPR{N}",
            qvalue          = config['macs3']['qvalue'],
            mode            = "{broad_narrow}",
            outdir          = "SPR_IDR/macs3/{broad_narrow}"
        log:
            "SPR_IDR/macs3/{broad_narrow}/{condition}_rep{rep}_rep{rep2}_SPR{N}.out"
        container:
            config['apptainers']['macs3']
        shell:
            """
            format_opt="-f BAM"
            if [ "{params.paired}" = "True" ]; then format_opt="-f BAMPE"; fi
            broad_opt=""
            if [ "{params.mode}" = "broad" ]; then
                broad_opt="--broad --broad-cutoff {params.broad_cutoff}"
            fi
            macs3 callpeak -B --SPMR \
                -t {input.inputs} \
                -c {input.controls} \
                -g {params.genome_size} \
                -n {params.prefix} \
                --bw {params.bandwidth} \
                {params.options} \
                -q {params.qvalue} \
                $format_opt \
                $broad_opt \
                --outdir {params.outdir} > {log} 2>&1
            """


    rule self_pseudo_replicate_idr:
        input:
            "SPR_IDR/macs3/{broad_narrow}/{condition}_rep{rep}_rep1_SPR{N}_peaks.{broad_narrow}Peak",
            "SPR_IDR/macs3/{broad_narrow}/{condition}_rep{rep}_rep2_SPR{N}_peaks.{broad_narrow}Peak"
        output:
            "SPR_IDR/idr/{broad_narrow}/{condition}_rep{rep}_SPR{N}.csv"
        params:
            rank=config['idr']['rank'],
            soft_idr_threshold=config['idr']['soft_idr_threshold']
        container:
            config['apptainers']['idr']
        log:
            out="SPR_IDR/idr/{broad_narrow}/{condition}_rep{rep}_SPR{N}.out",
            err="SPR_IDR/idr/{broad_narrow}/{condition}_rep{rep}_SPR{N}.err"
        shell:
            """
            idr --samples {input} --input-file-type {wildcards.broad_narrow}Peak --rank {params.rank} \
                --output-file SPR_IDR/idr/{wildcards.broad_narrow}/{wildcards.condition}_rep{wildcards.rep}_SPR{wildcards.N} \
                --plot --soft-idr-threshold {params.soft_idr_threshold} 1>{log.out} 2>{log.err}
            mv SPR_IDR/idr/{wildcards.broad_narrow}/{wildcards.condition}_rep{wildcards.rep}_SPR{wildcards.N} {output}
            """
    expected_output += expand("SPR_IDR/idr/{broad_narrow}/{condition}_rep{rep}_SPR{N}.csv", broad_narrow=['broad','narrow'], condition=cc.conditions, N=range(1, config['idr'].get('self_pseudo_replicates',1)+1), rep=[1,2])


if config['idr']['do'] and config['idr']['pseudo_replicates']:
    # =========================================================================
    # ================================================= pseudo replicates  ====
    # =========================================================================
    rule pseudo_replicate_data:
        input:
            bamfiles=[
                get_final_bam_location("IP_{condition}_rep1"),
                get_final_bam_location("IP_{condition}_rep2")]
        output:
            tmp_merged_bam=temp("PR_IDR/{condition}_PR{N}.bam"),
            tmp_split0=temp("PR_IDR/{condition}_PR{N}00"),
            tmp_split1=temp("PR_IDR/{condition}_PR{N}01"),
            tmp_header=temp("PR_IDR/{condition}_PR{N}_header.txt"),
            rep1="PR_IDR/{condition}_rep1_PR{N}.bam",
            rep2="PR_IDR/{condition}_rep2_PR{N}.bam"
        container:
            config['apptainers']['sequana_tools']
        log:
            "PR_IDR/{condition}_PR{N}.log"
        shell:
            """
            # merge treatment BAMs
            samtools merge -u {output.tmp_merged_bam} {input.bamfiles} > {log}

            # keep header for later
            samtools view -H {output.tmp_merged_bam} 1> {output.tmp_header} 2>> {log}

            # how many lines do we have ?
            nlines=$(samtools view {output.tmp_merged_bam} | wc -l)
            nlines=$(( (nlines + 1) / 2 ))

            # shuffle data and split in 2 files
            samtools view {output.tmp_merged_bam} | shuf - | split -d -l ${{nlines}} - PR_IDR/{wildcards.condition}_PR{wildcards.N} >> {log}

            cat {output.tmp_header} {output.tmp_split0} | samtools view -bS -> {output.rep1}
            cat {output.tmp_header} {output.tmp_split1} | samtools view -bS -> {output.rep2}

            # cleanup
            # input file is kept unchanged but in case there are several, we could do the same
            # operations as above.
            """

    rule pseudo_replicate_peaks:
        input:
            inputs="PR_IDR/{condition}_{rep}_PR{N}.bam",
            controls = get_final_bam_location("Input_{condition}")
        output:
            "PR_IDR/macs3/{broad_narrow}/{condition}_{rep}_PR{N}_peaks.{broad_narrow}Peak"
        params:
            bandwidth       = config['macs3']['bandwidth'],
            genome_size     = config['macs3']['genome_size'],
            options         = config['macs3']['options'],
            broad_cutoff    = config['macs3']['broad_cutoff'],
            paired          = manager.paired,
            prefix          = "{condition}_{rep}_PR{N}",
            qvalue          = config['macs3']['qvalue'],
            mode            = "{broad_narrow}",
            outdir          = "PR_IDR/macs3/{broad_narrow}"
        log:
            "PR_IDR/macs3/{broad_narrow}/{condition}_{rep}_PR{N}.log"
        container:
            config['apptainers']['macs3']
        shell:
            """
            format_opt="-f BAM"
            if [ "{params.paired}" = "True" ]; then format_opt="-f BAMPE"; fi
            broad_opt=""
            if [ "{params.mode}" = "broad" ]; then
                broad_opt="--broad --broad-cutoff {params.broad_cutoff}"
            fi
            macs3 callpeak -B --SPMR \
                -t {input.inputs} \
                -c {input.controls} \
                -g {params.genome_size} \
                -n {params.prefix} \
                --bw {params.bandwidth} \
                {params.options} \
                -q {params.qvalue} \
                $format_opt \
                $broad_opt \
                --outdir {params.outdir} > {log} 2>&1
            """


    rule pseudo_replicate_idr:
        input:
            ["PR_IDR/macs3/{broad_narrow}/{condition}_rep1_PR{N}_peaks.{broad_narrow}Peak",
            "PR_IDR/macs3/{broad_narrow}/{condition}_rep2_PR{N}_peaks.{broad_narrow}Peak"]
        output:
            "PR_IDR/idr/{broad_narrow}/{condition}_PR{N}.csv"
        log:
            out="PR_IDR/idr/{broad_narrow}/{condition}_PR{N}.out",
            err="PR_IDR/idr/{broad_narrow}/{condition}_PR{N}.err"
        params:
            rank=config['idr']['rank'],
            soft_idr_threshold=config['idr']['soft_idr_threshold']
        container:
            config['apptainers']['idr']
        shell:
            """
            idr --samples {input} --input-file-type {wildcards.broad_narrow}Peak --rank {params.rank} \
                --output-file PR_IDR/idr/{wildcards.broad_narrow}/{wildcards.condition}_PR{wildcards.N} \
                --plot --soft-idr-threshold {params.soft_idr_threshold} 1>{log.out} 2>{log.err}
            mv PR_IDR/idr/{wildcards.broad_narrow}/{wildcards.condition}_PR{wildcards.N} {output}
            """

    expected_output += expand("PR_IDR/idr/{broad_narrow}/{condition}_PR{N}.csv", broad_narrow=['broad','narrow'], condition=cc.conditions, N=range(1, config['idr'].get('pseudo_replicates',1)+1))

    # No further analysis (plotting, annotation, etc) since we only want to use the pseudo_replicate_idr
    # to check the robustess of the number of peaks identified in common in the 2 replicates.

    NPR = config['idr'].get('pseudo_replicates',1) + 1
    rule pseudo_replicate_plotting:
        input:
            expand("PR_IDR/idr/{mode}/{condition}_PR{i}.csv",
                        mode=['broad','narrow'],
                        condition=cc.conditions,
                        i=range(1, NPR)),
            expand("IDR/{mode}/{condition}.csv",
                        mode=['broad','narrow'],
                        condition=cc.conditions
                        )
        output:
            images=expand("outputs/IDR_NT_vs_PR_{mode}.png", mode=['narrow','broad']),
            csv=expand("outputs/IDR_NT_vs_PR_{mode}.csv", mode=['narrow','broad'])
        params:
            idr=0.05
        run:
            import pylab
            from sequana.idr import IDR
            import pandas as pd
            from collections import defaultdict

            for mode in ['broad','narrow']:
                pylab.clf()
                df = []
                NPRs = defaultdict(list)
                for condition in cc.conditions:
                    for i in range(1, NPR):
                        idr = IDR(f"PR_IDR/idr/{mode}/{condition}_PR{i}.csv")
                        try:
                            NPRs[condition].append(len(idr.df.query('idr<@params.idr')))
                        except: # df may be empty
                            NPRs[condition].append(0)
                df = pd.DataFrame(NPRs)
                # sort columns
                df = df[sorted(df.columns)]
                df.to_csv(f"outputs/IDR_NT_vs_PR_{mode}.csv")
                df.boxplot()
                # plot boxplot and real IDR values
                for i,condition in enumerate(df.columns):
                    idr = IDR(f"IDR/{mode}/{condition}.csv")
                    try:
                        pylab.plot([i+1], [len(idr.df.query("idr<@params.idr"))], 'ok')
                    except: # df may be empty
                        NPRs[condition].append(0)
                pylab.title(f"{mode} case")
                pylab.ylabel('Number of IDR peaks')
                pylab.savefig(f"outputs/IDR_NT_vs_PR_{mode}.png", dpi=200)

    expected_output += ["outputs/IDR_NT_vs_PR_narrow.png", "outputs/IDR_NT_vs_PR_broad.png"]


# ========================= peak counts summary for individual BAM files

rule plot_peak_count:
    input: [f"macs3/narrow/{k}_peaks.narrowPeak" for k in design.keys()] +
           [f"macs3/broad/{k}_peaks.broadPeak" for k in design.keys()]
    output:
        image = ["outputs/peak_broad_counts.png", "outputs/peak_narrow_counts.png"],
        csv = ["outputs/peak_broad_counts.csv", "outputs/peak_narrow_counts.csv"]
    run:
        import pandas as pd
        import pylab
        from sequana.macs3 import MACS3Reader

        for mode in ('narrow', 'broad'):
            npeaks = []
            labels = []
            types = []
            for filename in input:
                df = MACS3Reader(filename).df
                if filename.endswith(f"{mode}Peak"):
                    npeaks.append(len(df))
                    labels.append(filename.split("/")[-1].replace(f"_peaks.{mode}Peak", ""))
                    types.append(mode)

            df = pd.DataFrame({"comparison": labels, "npeaks": npeaks, 'type': types})
            df.to_csv(f"outputs/peak_{mode}_counts.csv", index=False)

            pylab.bar(range(len(npeaks)), height=npeaks, tick_label=labels)
            pylab.ylabel("Number of peaks")
            pylab.grid(True)
            pylab.title(f"{mode}")
            pylab.savefig(f"outputs/peak_{mode}_counts.png", dpi=200)

for mode in ['broad','narrow']:
    expected_output += [f"outputs/peak_{mode}_counts.png", f"outputs/peak_{mode}_counts.csv"]


if config['idr']['do']:
    ######################## ANNOTATE IDR PEAKS  ##################################################
    rule annotate_peaks_idr:
        input:
            macs3="IDR/{broad_narrow}/{comp}.csv",
            macs3_significative_only="IDR/{broad_narrow}/{comp}_significative.csv",
            fasta = fasta_file,
            gff   = gff_file
        output:
            annotations = "annotate_peaks_idr/{broad_narrow}/{comp}.txt",
            annotations_significative_only = "annotate_peaks_idr/{broad_narrow}/{comp}_significative.txt"
        threads: 1
        log:
            "annotate_peaks_idr/{broad_narrow}/{comp}.log"
        container:
            config['apptainers']['homer']
        shell:
            """
            annotatePeaks.pl {input.macs3} {input.fasta} -gid -gff {input.gff} -cpu {threads} 1>{output.annotations} 2>{log}
            annotatePeaks.pl {input.macs3_significative_only} {input.fasta} -gid -gff {input.gff} -cpu {threads} 1>{output.annotations_significative_only} 2>>{log}
            """

    expected_output += expand( "annotate_peaks_idr/{broad_narrow}/{comp}.txt", 
                broad_narrow=['broad', 'narrow'], 
                comp=cc.get_idr_NT_inputs().keys())
    expected_output += expand( "annotate_peaks_idr/{broad_narrow}/{comp}_significative.txt", 
               broad_narrow=['broad', 'narrow'], 
               comp=cc.get_idr_NT_inputs().keys())


    rule plot_annotated_peaks_idr_significative:
        input:
            annotations = "annotate_peaks_idr/{broad_narrow}/{comp}_significative.txt"
        output:
            png = "annotate_peaks_idr/{broad_narrow}/{comp}_significative.png"
        run:
            from sequana.homer import Homer
            from pylab import savefig

            h = Homer(input[0])
            h.pie_annotation()
            savefig(output[0], dpi=200)

    expected_output += expand("annotate_peaks_idr/{broad_narrow}/{comp}_significative.png",
                broad_narrow=['broad', 'narrow'],
                comp=cc.get_idr_NT_inputs().keys())



    #################### FEATURE COUNTS ON IDR PEAKS ###############################################
    rule idr_2_saf:
        input:
            "IDR/{broad_narrow}/{comp}.csv"
        output:
            "IDR/{broad_narrow}/{comp}.saf"
        run:
            from sequana.idr import IDR
            import pandas as pd
            df = IDR(input[0]).df
            if len(df):
                df['Strand'] = "+"
                df['GeneID'] = df.index
                df = df[["GeneID", "chrom", "start", "end", "Strand"]]
                df.columns = ['GeneID', 'Chr', 'Start', 'End', 'Strand']
                df.to_csv(output[0], sep="\t", index=None)
            else:
                df = pd.DataFrame(columns=['GeneID', 'Chr', 'Start', 'End', 'Strand'])
                df.loc[0] = ["A", 1,1,1,"+"]
                df.to_csv(output[0], sep="\t", index=None)

    rule feature_counts:
        input:
            saf="IDR/{broad_narrow}/{comp}.saf",
            bamfiles=expand(get_final_bam_location(), sample=cc.df.query("type=='IP'").sample_name.values)
        output:
            "featureCounts/{broad_narrow}/{comp}.feature_counts.out"
        threads: 4
        log:
            "feature_counts/{broad_narrow}/{comp}.log"
        params:
            paired = " -p --donotsort " if manager.paired else " "
        container:
            config['apptainers']['sequana_tools']
        shell:
            """
                featureCounts -FSAF -O --fracOverlap 0.2 -T {threads} {params.paired} -a {input.saf} -o {output} {input.bamfiles} >{log} 2>&1
            """
    expected_output += expand("featureCounts/{broad_narrow}/{comp}.feature_counts.out", broad_narrow=['broad', 'narrow'], comp=cc.get_idr_NT_inputs().keys())


if config['idr']['do']:

    static_idr = cc.get_idr_NT_inputs().keys()
    rule plot_idr_peak_counts:
        input:
            [f"IDR/narrow/{comp}.csv" for comp in static_idr] + [f"IDR/broad/{comp}.csv" for comp in static_idr]
        output:
            "outputs/idr_peak_counts.png"
        run:
            from sequana.idr import IDR
            import pylab

            N = len(input) / 2
            X = range(int(N))
            labels = static_idr
            narrow = {'N':[], 'Ns':[]}
            broad = {'N':[], 'Ns':[]}
            for filename in input:
                c = IDR(filename)
                if "/narrow/" in filename:
                    narrow['N'].append(len(c.df))
                    narrow['Ns'].append(c.N_significant_peaks or 0)
                elif "/broad/" in filename:
                    broad['N'].append(len(c.df))
                    broad['Ns'].append(c.N_significant_peaks or 0)

            f, axes = pylab.subplots(1,2, figsize=(10,6))

            axes[0].bar(X, narrow['N'], label='Peaks found in common')
            axes[0].bar(X, narrow['Ns'], label='Significant peaks found in common')
            pylab.sca(axes[0])
            pylab.xticks(X, labels)

            axes[1].bar(X, broad['N'], label='Peaks found in common')
            axes[1].bar(X, broad['Ns'], label='Significant peaks found in common')
            axes[1].legend(loc='upper right')
            pylab.sca(axes[1])
            pylab.xticks(X, labels)

            pylab.savefig(output[0])

    expected_output += ["outputs/idr_peak_counts.png"]


#FIXME add macs3 in input
rule igv_list:
    input:
        design="design.csv",
        gff=gff_file,
        samples=expand("{sample}/bigwig/{sample}.bigwig", sample=manager.samples),
        narrow=expand("IDR/narrow/{condition}_significative_peaks.narrowPeak", condition=cc.conditions),
        broad=expand("IDR/broad/{condition}_significative_peaks.broadPeak", condition=cc.conditions)
    output:
        "igv_list.txt"
    run:
        from sequana_pipelines.chipseq.tools import ChIPExpDesign
        c = ChIPExpDesign(input.design)
        conditions = c.conditions
        colors = ["blue", "red", "green", "orange", "purple", "cyan", "magenta", "brown"] * 4
        with open(output[0], "w") as fout:
            for i, condition in enumerate(c.conditions):
                for sample in c.df.query("condition==@condition").sample_name:
                    fout.write(f"{sample}/bigwig/{sample}.bigwig\t{colors[i]}\n")
                    if not sample.startswith('Input_'):
                        sample_no_IP = sample.replace("IP_", "").replace("_rep", "_")
                        fout.write(f"macs3/narrow/{sample_no_IP}_peaks.narrowPeak\t{colors[i]}\n")
                        fout.write(f"macs3/broad/{sample_no_IP}_peaks.broadPeak\t{colors[i]}\n")
                if config['idr']['do']:
                    fout.write(f"IDR/broad/{condition}_significative_peaks.broadPeak\t{colors[i]}\n")
                    fout.write(f"IDR/narrow/{condition}_significative_peaks.narrowPeak\t{colors[i]}\n")

            fout.write(f"{input.gff}\tblack\n")



rule igv:
    """igv list should contain a list of bigwig files and colors + gff (tabulated)"""
    input:
        "igv_list.txt"
    output:
        xml="igv.xml"
    run:

        filelist = []
        colors = []

        with open(input[0], "r") as fin:
            for line in fin:
                if line.strip().split():
                    f, c = line.strip().split()
                    filelist.append(f)
                    colors.append(c)

        xml = f"""<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<Session genome="{fasta_file}" hasGeneTrack="true" hasSequenceTrack="true" locus="All" version="8">
<Resources>"""
        for ifile,color in zip(filelist, colors):
            xml += '\t\t<Resource path="%s"/>\n' % (ifile)
        xml += '\t</Resources>\n'

        xml += '\t<Panel height="1160" name="DataPanel" width="1897">\n'
        for ifile,color in zip(filelist, colors):
            extension = os.path.splitext(ifile)[1].lower()
            if extension in ['.bed','.broadpeak','.narrowpeak']:
                xml += '\t\t<Track altColor="0,0,178" autoScale="false" clazz="org.broad.igv.track.FeatureTrack" color="%s" ' % (color)
                xml += 'displayMode="SQUISHED" featureVisibilityWindow="-1" fontSize="10" height="20" '
                xml += 'id="%s" name="%s" renderer="BASIC_FEATURE" sortable="false" visible="true" windowFunction="count"/>\n' % (ifile,os.path.basename(ifile))
            elif extension in ['.bw', '.bigwig', '.tdf']:
                xml += '\t\t<Track altColor="0,0,178" autoScale="true" clazz="org.broad.igv.track.DataSourceTrack" color="%s" ' % (color)
                xml += 'displayMode="COLLAPSED" featureVisibilityWindow="-1" fontSize="10" height="30" '
                xml += 'id="%s" name="%s" normalize="false" renderer="BAR_CHART" sortable="true" visible="true" windowFunction="mean">\n' % (ifile,os.path.basename(ifile))
                xml += '\t\t\t<DataRange baseline="0.0" drawBaseline="true" flipAxis="false" maximum="10" minimum="0.0" type="LINEAR"/>\n'
                xml += '\t\t</Track>\n'
            elif extension in ['.gtf']:
                xml += '\t\t<Track altColor="0,0,178" autoScale="false" clazz="org.broad.igv.track.FeatureTrack" color="%s" ' % (color)
                xml += 'displayMode="COLLAPSED" featureVisibilityWindow="-1" fontSize="10" '
                xml += 'id="%s" name="%s" renderer="BASIC_FEATURE" sortable="false" visible="true" windowFunction="count"/>\n' % (ifile,os.path.basename(ifile))
            elif extension in ['.bam']:
                pass
            else:
                xml += '\t\t<Track altColor="0,0,178" autoScale="false" clazz="org.broad.igv.track.FeatureTrack" color="%s" ' % (color)
                xml += 'displayMode="SQUISHED" featureVisibilityWindow="-1" fontSize="10" height="20" '
                xml += 'id="%s" name="%s" renderer="BASIC_FEATURE" sortable="false" visible="true" windowFunction="count"/>\n' % (ifile,os.path.basename(ifile))

        xml += '\t</Panel>\n</Session>'
        with open(output.xml, 'w') as fout:
            fout.write(xml)


# ========================================================== multiqc
multiqc_params_options = config['multiqc']['options']
if manager.config.multiqc.config_file:
    multiqc_params_options += f" -c {manager.config.multiqc.config_file}"
 
rule multiqc:
    input:
        expected_output
    output:
       "multiqc/multiqc_report.html"
    params:
        options=multiqc_params_options,
        input_directory=config['multiqc']['input_directory'],
        config_file=config['multiqc']['config_file'],
        modules=config['multiqc']['modules']
    resources:
        **config['multiqc']['resources']
    container:
        config["apptainers"]["multiqc"]
    log:
        "multiqc/multiqc.log"
    shell:
        manager.get_shell("multiqc/run", "v1")


os.makedirs("rulegraph", exist_ok=True)
shutil.copy("design.csv", "rulegraph/")

# ========================================================== rulegraph
rule rulegraph:
    input: str(manager.snakefile)
    output:
        svg = "rulegraph/rulegraph.dot"
    params:
        mapper = {"multiqc": "../multiqc/multiqc_report.html"},
        configname = "config.yaml"
    run:
        manager.get_run("rulegraph/run", "v1")(input, output, params)


rule dot2svg:
    input:
        "rulegraph/rulegraph.dot"
    output:
        ".sequana/rulegraph.svg"
    container:
        config['apptainers']['graphviz']
    shell:
        manager.get_shell("graphviz/dot2svg", "v1")


# Those rules takes a couple of seconds so no need for a cluster
localrules: rulegraph


onsuccess:

    import glob
    from sequana import logger
    from sequana.modules_report.summary import SequanaReport
    from sequana.utils.datatables_js import DataTable
    from sequana.utils.df2html import df2html
    from sequana.idr import IDR
    from sequana.macs3 import MACS3Reader
    from sequana_pipelines.chipseq import version

    import colorlog
    import pandas as pd
    from plotly import offline

    # cleanup
    log = colorlog.getLogger("sequana.chipseq")
    log.setLevel("INFO")

    manager.teardown(
        extra_files_to_remove=[ "requirements.txt"],
        extra_dirs_to_remove=[])
    manager.clean_multiqc("multiqc/multiqc_report.html")


    # THE HTML REPORT is defined hereafter
    #
    data = {"name": "chipseq",
            "rulegraph":".sequana/rulegraph.svg",
            "stats": "stats.txt",
            "pipeline_version": version}

    intro = f"""
    <h2>Overview</h2>
    <p>
    The ChIP-seq pipeline from Sequana maps IP and Input reads to the provided reference
    (<code>{fasta_file}</code>). Peaks are called with macs3 (narrow and broad) and
    IDR statistics are computed across replicates to identify reproducible peaks.
    </p>

    <p>A <a href="multiqc/multiqc_report.html">MultiQC report</a> is also available,
    providing complementary QC and mapping-quality plots across all samples.
    </p>

    <h2>Output structure</h2>
    <p>Each sample has its own directory containing sub-directories for each processing
    step: read trimming (<code>fastp/</code>), quality control (<code>fastqc_raw/</code>
    and <code>fastqc_clean/</code>), alignment (<code>bowtie2/</code>), coverage tracks
    (<code>bigwig/</code>), and phantom peak analysis (<code>phantom/</code>).
    Single-replicate peak files are in <code>macs3/</code> (narrow and broad) with
    annotations in <code>annotate_peaks/</code>. IDR peak analysis is in <code>IDR/</code>
    with annotations in <code>annotate_peaks_idr/</code>. Pseudo-replicate IDR working
    directories (<code>PR_IDR/</code> and <code>SPR_IDR/</code>) are summarised in this
    report and may be safely removed after the analysis is complete.
    </p>


    """

    intro += """
    <h2>QC plots</h2>
    <h3>Phantom peaks</h3>
    <p>Phantom peaks appear in poor-quality ChIP-seq samples. They can be detected by
    computing the strand cross-correlation from the BAM files. In a good experiment,
    the cross-correlation profile shows a clear peak at the fragment length
    (typically 100&ndash;200 bp). Phantom peaks appear near position 0 (the read length)
    and indicate poor enrichment.</p>
    <p>Two summary metrics are reported:</p>
    <ul>
      <li><b>NSC</b> (Normalised Strand Cross-correlation): ratio of the peak
          cross-correlation to the background cross-correlation. A value of 1 means no
          enrichment; values &gt; 1.1 are generally considered acceptable.</li>
      <li><b>RSC</b> (Relative Strand Correlation): ratio of the fragment-length peak
          to the phantom peak. Values &gt; 1 indicate good enrichment. RSC is used to
          assign a quality tag:</li>
    </ul>
<ul>
<li>Qtag &minus;2: RSC &lt; 0.25 (very poor quality)</li>
<li>Qtag &minus;1: RSC in [0.25, 0.5)</li>
<li>Qtag 0: RSC in [0.5, 1)</li>
<li>Qtag 1: RSC in [1, 1.5)</li>
<li>Qtag 2: RSC &ge; 1.5 (good quality)</li>
</ul>
    """

    df = pd.DataFrame([
        pd.read_json(f"{sample}/phantom/phantom.json", typ="series") for sample in cc.df['sample_name']
    ])
    df.corr_max = df.corr_max.round(3)
    df.phantom_corr = df.phantom_corr.round(3)
    df.NSC = df.NSC.round(2)
    df.RSC = df.RSC.round(2)
    df['sample_name'] = cc.df['sample_name']
    df = df[['sample_name', 'read_fragments', 'corr_max', 'NSC', 'RSC', 'Qtag']]
    intro +=  df2html(df, show_index='sample_name')
 

    intro += """
         <!--<script src="https://ajax.googleapis.com/ajax/libs/jquery/1.11.1/jquery.min.js"></script>-->
         <!-- Fotorama from CDNJS, 19 KB -->
         <link  href="https://cdnjs.cloudflare.com/ajax/libs/fotorama/4.6.4/fotorama.css" rel="stylesheet">
         <script src="https://cdnjs.cloudflare.com/ajax/libs/fotorama/4.6.4/fotorama.js"></script>
    """
    intro +='<div class="fotorama" fzyz-keyboard="true" '
    intro +=' data-nav="thumbs"'
    intro +=' data-loop="true"'
    intro += ' data-width="100%"'
    intro += ">"

    files = glob.glob("*/phantom/phantom.png")
    captions = [filename.split("/")[0] for filename in files]
    for filename, caption in zip(files, captions):
        intro += '<img src="{}" data-caption="{}">'.format(filename, caption)
    intro +="</div>"

    intro += """
    <h3>FRiP</h3>
    <p>FRiP (Fraction of Reads in Peaks) measures the proportion of reads that fall
    within detected peaks. Peaks can be narrow or broad, and are always called for a
    specific IP versus its matched control. In a well-enriched ChIP-seq experiment,
    IP samples should show higher FRiP values than their Input/control counterparts,
    and replicates within the same condition should behave consistently. Each plot below
    shows all samples evaluated against peaks called from one specific IP&ndash;control
    comparison.</p>"""
    intro +='<div class="fotorama" fzyz-keyboard="true" data-nav="thumbs" data-loop="true" data-width="100%" >'
    files = glob.glob("FRiP/*/*.png")
    captions = ["/".join(filename.split("/")[1:]) for filename in files]
    for filename, caption in zip(files, captions):
        intro += '<img src="{}" data-caption="{}">'.format(filename, caption)
    intro +="</div>"


    intro+="""
    <h2>Results</h2>
    <h3>Experimental design</h3>
    <div><p>The table below lists all samples with their type (IP for immunoprecipitated, or Input for control), condition, and replicate number. The sample name is derived from the input filename prefix.</p></div>

    """
    intro += df2html(cc.df)
    intro += """
    <h3>Single peak detection</h3>
    <p>The following files contain peaks detected for each IP&ndash;control comparison within the same condition.
    If there are multiple controls for a condition, they are combined into a single control track.
    If there are several IP replicates for a condition, peaks are called for each replicate individually
    and also for the pooled replicates. Both narrow and broad peak calls are reported.
    Peak files are in macs3 format (10 columns for narrow peaks, 9 for broad):
    chromosome, start, end, name, score, strand, fold-enrichment, &minus;log10(p-value),
    &minus;log10(q-value), and summit offset from start (narrow only).</p>
    """

    keys = sorted(cc.get_IP_versus_control().keys())
    narrow = [f"{key}_peaks.narrowPeak" for key in keys]
    narrow_links = [f"macs3/narrow/{key}_peaks.narrowPeak" for key in keys]
    broad = [f"{key}_peaks.broadPeak" for key in keys]
    broad_links = [f"macs3/broad/{key}_peaks.broadPeak" for key in keys]
    df = pd.DataFrame({'narrow': narrow, 'narrow_links':narrow_links,
                       'broad': broad, 'broad_links':broad_links}, index=keys)
    intro += df2html(df, dom='rt', show_index=True) + "<br>"
    intro += "<p>The plots below summarize the number of peaks per type (narrow and broad) across all combinations of IP samples versus their matched controls.</p>"

    intro += SequanaReport.png_to_embedded_png("peak_narrow_counts", "outputs/peak_narrow_counts.png", style="width:48%; max-width:600px")
    intro += SequanaReport.png_to_embedded_png("peak_broad_counts", "outputs/peak_broad_counts.png", style="width:48%; max-width:600px")


    for key in keys:
        ph = MACS3Reader(f"macs3/narrow/{key}_peaks.narrowPeak")
        fig = ph.plot_volcano(plotly=True,  title=f"narrow {key}")
        intro += offline.plot(fig, output_type='div', include_plotlyjs=True)
    for key in keys:
        ph = MACS3Reader(f"macs3/broad/{key}_peaks.broadPeak")
        fig = ph.plot_volcano(plotly=True,  title=f"broad {key}")
        intro += offline.plot(fig, output_type='div', include_plotlyjs=True)
     
    # ===================================================== single peak annotation plots 
    intro += """<h3>Single peak annotation</h3>
    <div class="fotorama" fzyz-keyboard="true" data-nav="thumbs" data-loop="true" data-width="100%">"""

    files = glob.glob("annotate_peaks/narrow/*png") + glob.glob("annotate_peaks/broad/*png")
    captions = files
    for filename, caption in zip(files, captions):
        intro += '<img src="{}" data-caption="{}">'.format(filename, caption)
    intro +="</div>"

    # ===================================================== naive peak consensus venn diagram plots
    if config["idr"]["do"]:
        intro += "<h3>Naive peak consensus (overlap replicates)</h3>"
        for cond in cc.get_idr_NT_inputs().keys():
            for mode in ['narrow', 'broad']:
                intro += SequanaReport.png_to_embedded_png(f"peak_{mode}_{cond}_venn", f"macs3/{mode}/{cond}_venn.png", style="width:30%; max-width:400px")


    # ===================================================== IDR
    intro += """<h3>IDR peak detection</h3><h4>Overview</h4>
    <p>The figures below show the number of significant peaks found in common across replicates (blue) and the subset
    passing the IDR threshold (orange). IDR is computed only when at least 2 replicates are available.</p>"""


    if config['idr']['do']:
        #intro+= SequanaReport.png_to_embedded_png("peak_counts", "outputs/idr_peak_counts.png",
        #    style="width:80%; height:40%;")
        for peak_type in ['narrow', 'broad']:
            for key in cc.get_idr_NT_inputs().keys():


                # all data
                intro += f"<h4><u>Case replicate {key} ({peak_type})</u></h4>"
                idr = IDR(f"IDR/{peak_type}/{key}.csv")
                df = idr.df
                intro += f"<p>A total of {len(df)} peaks were found after IDR analysis and {idr.N_significant_peaks} are found with an IDR<0.05</p>"
                intro += df2html(df, dom='Bfrtip')

                intro +='<div class="fotorama" fzyz-keyboard="true" '
                intro +=' data-nav="thumbs"'
                intro +=' data-loop="true"'
                intro += ' data-width="100%"'
                intro += ">"

                files = [f"IDR/{peak_type}/{key}_idr_vs_peaks.png",
                         f"IDR/{peak_type}/{key}_ranks.png",
                         f"IDR/{peak_type}/{key}_scores.png",
                         #f"macs3/{peak_type}/{key}_peak_consensus_venn.png",
                         f"IDR/{peak_type}/{key}_rank_idr.png"]

                captions = ["idr_vs_peaks. peaks below 0.05 are kept (red)", 
                            "ranks between peaks should agree (black are kept)", 
                            "log10 scores of each replicates (black are kept)", 
                            #"venn diagram common peaks", 
                            "compared ranks in both replicates"]
                intro += '<p>Standard IDR diagnostic plots for ChIP-seq analysis are shown below.</p>'
                for filename, caption in zip(files, captions):
                    intro += '<img src="{}" data-caption="{}">'.format(filename, caption)
                intro +="</div>"

                # significant only
                intro += f"<h4><u>Case replicate {key} ({peak_type}) &mdash; significant peaks only (IDR &lt; 0.05)</u></h4>"
                idr = IDR(f"IDR/{peak_type}/{key}_significative.csv")
                df = idr.df
                intro += df2html(df, dom='Bfrtip')

    # Pseudo replicates analysis
    if config['idr']['do'] and config['idr']['pseudo_replicates']:
        intro += """<h2>Pseudo replicates analysis</h2>"""
        intro += """<p>The number of peaks found in the pseudo-replicate analysis should agree with the true-replicate IDR.
        IDR on pooled pseudo-replicates should yield a peak count within a factor of 2 of the true-replicate IDR,
        which indicates robust replicates. Black dots show the true-replicate IDR peak count;
        boxplots show the distribution across pseudo-replicates. Peaks with IDR &gt; 0.05 are excluded.</p>"""

        intro += SequanaReport.png_to_embedded_png("IDR_NT_narrow",
                    "outputs/IDR_NT_vs_PR_narrow.png", style="width:48%; max-width:600px")
        intro += SequanaReport.png_to_embedded_png("IDR_NT_broad",
                    "outputs/IDR_NT_vs_PR_broad.png", style="width:48%; max-width:600px")

    if config['idr']['do'] and config['idr']['self_pseudo_replicates']:
        # Self pseudo replicates analysis
        intro += """<h2>Self pseudo replicates analysis</h2>
        <p>For each replicate, reads are randomly split into two equal halves (self-pseudo-replicates).
        IDR is then run on each pair of self-pseudo-replicates independently. The peak counts from
        the two halves should agree within a factor of 2; a higher ratio suggests the replicate
        itself is of poor quality. The table below shows the IDR peak counts for self-pseudo-replicate
        1 and 2, and their ratio, for each condition and peak type (narrow/broad).
        Ratios above 2 are highlighted in red.</p>"""



        # ===============================================  self pseudo replicates info
        N = len(cc.conditions) * 2 * 3 # {broad,narrow} x [Nidr in rep1,Nidr in rep2, ratio]
        intro +="""<table style="border:1px solid black; width:100%; table-layout: fixed"><tr>"""
        for cond in cc.conditions:
            intro+=f'<th colspan="6" style="border:1px solid black">{cond}</th>'
        intro+="</tr><tr>"
        for cond in cc.conditions:
            intro+='<th colspan="3" style="border:1px solid black">broad</th>'
            intro+='<th colspan="3" style="border:1px solid black">narrow</th>'
        intro+="</tr>"

        NSPR = config["idr"].get("self_pseudo_replicates", 1) +1

        for item in range(1, NSPR):
            intro+= "<tr>"
            for condition in cc.conditions:
                for mode in ['broad', 'narrow']:
                    _data = [len(IDR(f"SPR_IDR/idr/{mode}/{condition}_rep{rep}_SPR{item}.csv")) for rep in [1,2]]
                    try:
                        ratio = int(max(_data)/min(_data)*100)/100.
                    except ZeroDivisionError:
                        ratio = 4
                        pass
                    intro += f'<td style="border: 1px solid black">{_data[0]}</td>'
                    intro += f'<td style="border: 1px solid black">{_data[1]}</td>'
                    if ratio > 2:
                        intro += f'<td style="border: 1px solid black; background-color:#D53A2D">{ratio}</td>'
                    else:
                        intro += f'<td style="border: 1px solid black; background-color:#53CB59">{ratio}</td>'
            intro += "</tr>"

        intro +="""</table>"""

    # ========================================================== IDR peak annotation
    if config["idr"]["do"]:
        intro += """<h3>IDR peak annotation</h3>
        <div class="fotorama" fzyz-keyboard="true" data-nav="thumbs" data-loop="true" data-width="100%">"""

        files = glob.glob("annotate_peaks_idr/narrow/*png") + glob.glob("annotate_peaks_idr/broad/*png")
        captions = files
        for filename, caption in zip(files, captions):
            intro += '<img src="{}" data-caption="{}">'.format(filename, caption)
        intro +="</div>"


        for peak_type in ['narrow', 'broad']:
            for key in sorted(cc.conditions):
                from sequana.homer import Homer
                h = Homer(f"annotate_peaks_idr/{peak_type}/{key}_significative.txt")
                if 'ID' in h.df.columns:
                    del h.df['ID']
                intro += f"<h3><u>Case replicate {key} ({peak_type}) &mdash; significant peaks only (IDR &lt; 0.05)</u></h3>"
                intro += df2html(h.df, dom='Bfrtip', show_index=False)

    # ========================================================== Final information
    intro += """<h2>Final information</h2>"""
    intro += """<p>All alignments are in <code>&lt;sample&gt;/bowtie2/*.sorted.bam</code>. These files can be
loaded in a genome browser such as IGV, though bigwig files in <code>&lt;sample&gt;/bigwig/</code>
are recommended for faster browsing. An IGV session file (<code>igv.xml</code>) is provided that
preloads all bigwig tracks and per-replicate peak files.</p>

<p>IDR results are in the <code>IDR/</code> directory (separate <code>narrow/</code> and <code>broad/</code>
subdirectories) as CSV files. These correspond to the tables shown in the &ldquo;IDR peak detection&rdquo;
section above and contain both significant and non-significant peaks.</p>

"""

    s = SequanaReport(data, intro)

    shell("chmod -R g+w .")
    shell("rm -rf rulegraph")
onerror:
    manager.onerror()


