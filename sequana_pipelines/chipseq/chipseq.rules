expected_output.extend(expand("{sample}/fastqc_clean/fastqc.done", sample=manager.samples))


# ===================================================== mapping with bowtie2
if manager.config.general.aligner == "bowtie2":

    rule bowtie2_mapping:
        input:
            fastq=__clean_fastq__output,
                 idx=multiext(
                 bowtie2_index,
                 ".1.bt2",
                 ".2.bt2",
                 ".3.bt2",
                 ".4.bt2",
                 ".rev.1.bt2",
                 ".rev.2.bt2",
             ),
        output:
            bam="{sample}/bowtie2/{sample}.sorted.bam"
        log:
            "{sample}/bowtie2/{sample}.log"
        params:
            options=config["bowtie2_mapping"]["options"],
        threads:
            config["bowtie2_mapping"]["threads"]
        container:
            config["apptainers"]["sequana_tools"]
        resources:
             **config['bowtie2_mapping']['resources']
        shell:
            manager.get_shell("bowtie2/align", "v1")


# ===================================================== mark duplicates
# duplicates can be from PCR or if SR, by pure chance; if Paired, most likely a PCR origin.
# Mark duplicates
rule mark_duplicates:
    input:
        bam = f"{{sample}}/{aligner}/{{sample}}.sorted.bam"
    output:
        bam = "{sample}/mark_duplicates/{sample}.sorted.bam",
        metrics = "{sample}/mark_duplicates/{sample}.sorted.metrics",
    log:
        "{sample}/mark_duplicates/mark_dup.log"
    params:
        remove_dup = "false",
        tmpdir = "{sample}/mark_duplicates/tmp",
        options = config['mark_duplicates'].get('options', '')
    threads:
        config['mark_duplicates']['threads']
    container:
        config["apptainers"]["sequana_tools"]
    resources:
        **config['mark_duplicates']['resources']
    shell:
        manager.get_shell("mark_duplicates/run", "v1")


# ===================================================== blacklist

rule remove_blacklist:
    input:
        bam=get_final_bam_location("{sample}"),
        blacklist=config["remove_blacklist"]["blacklist_file"]
    output:
        bam="{sample}/blacklist/{sample}.sorted.bam"
    log:
        out="{sample}/blacklist/{sample}.out",
        err="{sample}/blacklist/{sample}.err",
    container:
        config["apptainers"]["sequana_tools"]
    shell:
        """
        # blacklist elements found in the input BED3 file.
        (intersectBed -v -abam {input.bam} -b {input.blacklist} > {output.bam}) && (samtools index {output.bam}) > {log.out} 2>{log.err}
        """


# ========================================================= plotCorrelation

rule plotCorrelation_npz:
    input:
        expand(
            "{sample}/bigwig/{sample}.bigwig",
             sample=manager.samples)
    output:
        "outputs/data.npz"
    params:
        bins=10000
    log:
        "logs/plotCorrelation.log"
    container:
        config["apptainers"]["sequana_tools"]
    shell:
        """
        multiBigwigSummary bins -b {input}  -o {output} -bs {params.bins} >{log} 2>&1
        """


rule plotCorrelation:
    input:
        "outputs/data.npz"
    output:
        "outputs/correlation.png"
    params:
        zMin=0
    log:
        "logs/plotCorrelation_plot.log"
    container:
        config["apptainers"]["sequana_tools"]
    shell:
        """
        plotCorrelation  --corData {input} --corMethod pearson -p heatmap --plotFile {output} --zMin {params.zMin} >{log} 2>&1
        """


# ===================================================== phantom detection using spp
rule phantom_spp:
    input:
        f"{{sample}}/{aligner}/{{sample}}.sorted.bam"
    output:
        pdf= "{sample}/phantom_spp/spp.pdf",
        rdata= "{sample}/phantom_spp/spp.Rdata",
        out= "{sample}/phantom_spp/spp.out",
    threads: 1
    log:
        out="{sample}/phantom_spp/{sample}.out",
        err="{sample}/phantom_spp/{sample}.err"
    container:
        config["apptainers"]["phantompeak"]
    shell:
        """
        run_spp.R -c={input} -savp={output.pdf} -savd={output.rdata}  -out={output.out} -p={threads} -rf 1>{log.out} 2>{log.err}
        """
if config['phantom']['use_spp']:
    expected_output += expand("{sample}/phantom_spp/spp.pdf", sample=manager.samples)


# ===================================================== phantom detection using sequana

rule phantom_align:
    input:
        f"{{sample}}/{aligner}/{{sample}}.sorted.bam"
    output:
        align=f"{{sample}}/{aligner}/{{sample}}.sorted.align"
    log:
        f"{{sample}}/{aligner}/{{sample}}.phantom_align.log"
    container:
        config["apptainers"]["samtools"]
    shell:
        """
        # Converting the SAM to alignment
        # note that for awk, we escape the braces by doubling them
        samtools view -F 0x0204  {input} | awk 'BEGIN {{FS="\\t";OFS="\\t"}} {{if (and($2,16) > 0) {{print $3,($4-1),($4-1+length($10)),"N","1000","-"}} else {{print $3,($4-1),($4-1+length($10)),"N","1000","+"}}}}' - > {output.align} 2>{log}
        """


rule phantom:
    input:
        align=f"{{sample}}/{aligner}/{{sample}}.sorted.align"
    output:
        png= "{sample}/phantom/phantom.png",
        json= "{sample}/phantom/phantom.json",
    log:
        "{sample}/phantom/phantom.log"
    threads: 1
    run:
        import json
        from pylab import savefig
        from sequana.phantom import Phantom

        # Reading alignments and computing cross correlation
        c = Phantom(binning=5)
        c.read_align(input.align)
        results, df = c.run()
        stats = c.stats(results, df)

        with open(output.json, "w") as fout:
            json.dump(stats, fout)

        savefig(output.png)


# ===================================================== get chrom size file
rule chrom_sizes:
    input:
        fasta_file
    output:
        "chrom.sizes"
    log:
        "logs/chrom_sizes.log"
    container:
        config["apptainers"]["sequana_tools"]
    shell:
        """
        samtools faidx {input} >{log} 2>&1
        cut -f 1,2 {input[0]}.fai > {output[0]}
        """


# ===================================================== fingerprints
# Did my ChIP work i.e. did the antibody-treatment enrich sufficiently so that the ChIP signal 
# can be separated from the background signal? around 90% of all DNA fragments in a 
# ChIP experiment will represent the genomic background.

# todo add this option
# --JDSSample + controls
rule fingerprints:
    input:
        expand("{sample}/{aligner}/{sample}.sorted.bam", sample=manager.samples, aligner=aligner)
    output:
        raw="fingerprints/plotFingerprint.raw.txt",
        metrics="fingerprints/plotFingerprint.qcmetrics.txt",
        pdf="fingerprints/plotFingerprint.pdf"
    log:
        "fingerprints/plotFingerprint.log"
    params:
        labels=" ".join(sorted(manager.samples)),
        bins=config['fingerprints']['bins']
